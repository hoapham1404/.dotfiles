SELECT
  TRNCONTRACT.CONTRACT_CD  ,
  MSTCONTRACT.CONTRACT_NAME,
  TRNCONTRACT.CNT_CLASS_CD ,
  MSTCNTCLASS.CNT_CLASS_NAME
FROM
  KTV.TRNCONTRACT,
  KTV.MSTCONTRACT,
  KTV.MSTCNTCLASS
WHERE
  TRNCONTRACT.CONTRACT_CD    = MSTCONTRACT.CONTRACT_CD
AND TRNCONTRACT.CNT_CLASS_CD = MSTCNTCLASS.CNT_CLASS_CD
AND TRNCONTRACT.DELETE_YMD IS NULL
AND TRNCONTRACT.CANCEL_YMD IS NULL
AND MSTCONTRACT.DELETE_YMD IS NULL
AND TRNCONTRACT.BLD_JOINT_NO = '2'
wORDER BY
  MSTCONTRACT.CONTRACT_CD,
  MSTCNTCLASS.CNT_CLASS_CD